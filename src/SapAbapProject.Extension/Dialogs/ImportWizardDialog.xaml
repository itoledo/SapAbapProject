<Window x:Class="SapAbapProject.Extension.Dialogs.ImportWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import from SAP System"
        Height="560" Width="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,12" Text="{Binding StepTitle}" />

        <!-- Step Content -->
        <Grid Grid.Row="1">
            <!-- Step 1: SAP Connection -->
            <Grid Visibility="{Binding IsStep1Visible}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TabControl Grid.Row="0" x:Name="Step1Tabs">
                    <!-- Recent Connections Tab -->
                    <TabItem Header="Recent">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ListBox Grid.Row="0" x:Name="RecentList"
                                     ItemsSource="{Binding RecentConnections}"
                                     SelectedItem="{Binding SelectedRecentConnection}"
                                     MouseDoubleClick="OnRecentDoubleClick"
                                     HorizontalContentAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                <TextBlock FontSize="11" Foreground="Gray">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="SysNr: {0} | Lang: {1}">
                                                            <Binding Path="SystemNumber"/>
                                                            <Binding Path="Language"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="  X  " VerticalAlignment="Center"
                                                    Click="OnDeleteRecent" Cursor="Hand"
                                                    ToolTip="Remove this connection"
                                                    Padding="4,2" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Grid.Row="0" Text="No saved connections yet."
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="Gray" FontStyle="Italic"
                                       Visibility="{Binding RecentEmptyVisibility}"/>

                            <TextBlock Grid.Row="1" Text="Select a connection and click Next, or double-click to use it"
                                       Foreground="Gray" FontSize="11" Margin="0,6,0,0"/>
                        </Grid>
                    </TabItem>

                    <!-- New Connection Tab -->
                    <TabItem Header="New Connection">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="App Server Host:" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding AppServerHost, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="System Number:" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SystemNumber, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Client:" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Client, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="User:" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding User, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,4"/>
                            <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="PasswordBox" Margin="0,4"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Language:" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Language, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="SAP Router:" VerticalAlignment="Center" Margin="0,4"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SapRouter, UpdateSourceTrigger=PropertyChanged}" Margin="0,4"
                                     ToolTip="SAP Router string, e.g. /H/saprouter.example.com/S/3299/H/"/>
                        </Grid>
                    </TabItem>
                </TabControl>

                <!-- Test Connection (shared across both tabs) -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <Button Content="Test Connection"
                            Command="{Binding TestConnectionCommand}"
                            HorizontalAlignment="Left" Padding="16,4"/>
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="{Binding ConnectionStatusColor}" Margin="0,4"/>
                </StackPanel>
            </Grid>

            <!-- Step 2: Package and Object Selection -->
            <Grid Visibility="{Binding IsStep2Visible}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Search for packages and select object types to import:" Margin="0,0,0,8"/>

                <!-- Package search -->
                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding PackageSearchPattern, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Enter a package name pattern (e.g., Z* or Y_CUSTOM*)" />
                    <Button Grid.Column="2" Content="Search Packages" Padding="12,4"
                            Command="{Binding SearchPackagesCommand}" />
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="Packages" Margin="0,0,4,0">
                        <ListBox ItemsSource="{Binding AvailablePackages}" Margin="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="Object Types" Margin="4,0,0,0">
                        <ListBox ItemsSource="{Binding AvailableObjectTypes}" Margin="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </GroupBox>
                </Grid>

                <!-- Optional filters -->
                <Grid Grid.Row="3" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="FM Name Pattern:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding FunctionModulePattern, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Optional: filter function modules by name pattern (e.g., Z_MY_FM*)" Margin="0,2"/>
                </Grid>

                <Grid Grid.Row="4" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Function Group:" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="{Binding FunctionGroupFilter, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Optional: filter by function group name" Margin="0,2"/>
                </Grid>

                <CheckBox Grid.Row="5" Content="Include documentation comments"
                          IsChecked="{Binding IncludeDocumentation}" Margin="0,8,0,0"/>

                <CheckBox Grid.Row="6" Content="Include function signatures"
                          IsChecked="{Binding IncludeSignature}" Margin="0,4,0,0"/>
            </Grid>

            <!-- Step 3: Progress -->
            <Grid Visibility="{Binding IsStep3Visible}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ProgressBar Grid.Row="0" Height="24" Minimum="0" Maximum="100"
                             Value="{Binding ProgressValue}" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Text="{Binding ProgressText}" Margin="0,0,0,8"/>

                <ListBox Grid.Row="2" ItemsSource="{Binding LogMessages}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="&lt; Back" Command="{Binding BackCommand}"
                    Width="80" Margin="0,0,8,0" Padding="4"/>
            <Button Content="{Binding NextButtonText}" Command="{Binding NextCommand}"
                    Width="80" Margin="0,0,8,0" Padding="4"/>
            <Button Content="Cancel" IsCancel="True"
                    Width="80" Padding="4"/>
        </StackPanel>
    </Grid>
</Window>
