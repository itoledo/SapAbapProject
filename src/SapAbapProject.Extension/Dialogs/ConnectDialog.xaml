<Window x:Class="SapAbapProject.Extension.Dialogs.ConnectDialog"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect to SAP System"
        Height="500" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" x:Name="MainTabs">

            <!-- Tab 1: Recent Connections -->
            <TabItem Header="Recent" x:Name="RecentTab">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0" x:Name="RecentList"
                             MouseDoubleClick="OnRecentDoubleClick"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Language, StringFormat='Language: {0}'}"
                                                   FontSize="11" Foreground="Gray"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="  X  " VerticalAlignment="Center"
                                            Click="OnDeleteRecent" Cursor="Hand"
                                            ToolTip="Remove this connection"
                                            Padding="4,2" Margin="8,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="0" x:Name="EmptyMessage"
                               Text="No saved connections yet."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="Gray" FontStyle="Italic"
                               Visibility="Collapsed"/>

                    <TextBlock Grid.Row="1" Text="Double-click a connection to connect"
                               Foreground="Gray" FontSize="11" Margin="0,6,0,0"/>
                </Grid>
            </TabItem>

            <!-- Tab 2: New Connection -->
            <TabItem Header="New Connection" x:Name="NewConnectionTab">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Import from Connection String -->
                    <GroupBox Grid.Row="0" Header="Import from Connection String" Margin="0,0,0,8">
                        <DockPanel Margin="4">
                            <Button DockPanel.Dock="Right" Content="Parse" Click="OnParseConnectionString"
                                    Padding="12,4" Margin="8,0,0,0"/>
                            <TextBox x:Name="ConnStringBox" VerticalAlignment="Center"
                                     ToolTip="Paste an SAP connection string (ASHOST=...;SYSNR=...;CLIENT=...) and click Parse"/>
                        </DockPanel>
                    </GroupBox>

                    <!-- Separator -->
                    <Separator Grid.Row="1" Margin="0,0,0,8"/>

                    <!-- Connection fields -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="App Server Host:" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="AppServerHostBox" Margin="0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="System Number:" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="SystemNumberBox" Text="00" Margin="0,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Client:" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="ClientBox" Text="100" Margin="0,4"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="User:" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="UserBox" Margin="0,4"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,4"/>
                        <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="PasswordBox" Margin="0,4"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Language:" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox Grid.Row="5" Grid.Column="1" x:Name="LanguageBox" Text="EN" Margin="0,4"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="SAP Router:" VerticalAlignment="Center" Margin="0,4"/>
                        <TextBox Grid.Row="6" Grid.Column="1" x:Name="SapRouterBox" Margin="0,4"
                                 ToolTip="SAP Router string, e.g. /H/saprouter.example.com/S/3299/H/"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status -->
        <TextBlock Grid.Row="1" x:Name="StatusText" Margin="0,8" TextWrapping="Wrap"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Connect" x:Name="ConnectButton" Click="OnConnect"
                    Width="80" Margin="0,0,8,0" Padding="4" IsDefault="True"/>
            <Button Content="Cancel" IsCancel="True" Width="80" Padding="4"/>
        </StackPanel>
    </Grid>
</Window>
