<platformUI:DialogWindow x:Class="SapAbapProject.Extension.Dialogs.SdkPathDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:platformUI="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
    Title="SAP NetWeaver RFC SDK Configuration"
    WindowStartupLocation="CenterOwner"
    Width="560" Height="280"
    ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap"
            Text="This extension requires the SAP NetWeaver RFC SDK to connect to SAP systems. Please specify the folder containing sapnwrfc.dll and its dependencies (ICU libraries)."/>

        <TextBlock Grid.Row="2" Text="SDK Path:" FontWeight="SemiBold"/>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SdkPathTextBox" Grid.Column="0" VerticalContentAlignment="Center"
                     TextChanged="SdkPathTextBox_TextChanged"/>
            <Button x:Name="BrowseButton" Grid.Column="2" Content="Browse..." Width="80"
                    Padding="8,4" Click="BrowseButton_Click"/>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock x:Name="ValidationText" Text="" Foreground="Gray"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkButton" Content="OK" Width="80" Padding="8,4" Margin="0,0,8,0"
                    IsEnabled="False" Click="OkButton_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Padding="8,4" IsCancel="True"/>
        </StackPanel>
    </Grid>
</platformUI:DialogWindow>
